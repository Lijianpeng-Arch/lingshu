{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lingshu.dev/schema/tools-metadata.v2.json",
  "title": "Lingshu V2 Tool Metadata",
  "description": "灵枢 V2 工具元数据 schema。metadata.json 必须通过本 schema 校验。",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated", "source", "tools"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "元数据 schema 版本 (semver)"
    },
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "生成时间 (ISO 8601)"
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "description": "来源源码路径"
    },
    "description": {
      "type": "string",
      "description": "可选: 元数据总体说明"
    },
    "schemaRef": {
      "type": "string",
      "description": "可选: 关联的 schema 路径"
    },
    "tools": {
      "type": "array",
      "minItems": 16,
      "description": "工具列表,当前 16 个内置工具",
      "items": { "$ref": "#/$defs/tool" }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "displayName",
        "displayDescription",
        "description",
        "category",
        "risk",
        "parameters",
        "borrowedFrom",
        "sourceFile"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z_]+$",
          "minLength": 1,
          "description": "工具名 (snake_case,英文)"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "description": "中文显示名 (用户面板)"
        },
        "displayDescription": {
          "type": "string",
          "minLength": 1,
          "description": "中文一句话描述 (用户面板)"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "完整英文描述 (含 borrowedFrom 标识)"
        },
        "category": {
          "type": "string",
          "enum": ["filesystem", "search", "git", "legacy"],
          "description": "工具分类"
        },
        "risk": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "风险等级 (决定默认权限档位)"
        },
        "parameters": {
          "type": "object",
          "required": ["type", "properties"],
          "description": "JSON Schema 风格的参数定义",
          "properties": {
            "type": { "const": "object" },
            "properties": { "type": "object" },
            "required": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "examples": {
          "type": "array",
          "description": "可选: 1-3 个真实可跑的示例",
          "items": {
            "type": "object",
            "required": ["description", "args", "expected"],
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string", "minLength": 1 },
              "args": { "type": "object" },
              "expected": { "type": "string", "minLength": 1 }
            }
          }
        },
        "borrowedFrom": {
          "type": "string",
          "minLength": 1,
          "description": "借鉴来源 (OpenCode / Hermes / BaiLongma / self)"
        },
        "sourceFile": {
          "type": "string",
          "minLength": 1,
          "description": "实现源码文件路径 (相对 repo root)"
        }
      }
    }
  }
}
